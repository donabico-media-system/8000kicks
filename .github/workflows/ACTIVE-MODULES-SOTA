name: ACTIVE-MODULES-SOTA

on:
  schedule:
    # Vòng lặp đệ quy quét module vô hạn mỗi 5 phút liên tục 24/7
    - cron: '*/5 * * * *'
  workflow_dispatch:

jobs:
  modules-sync:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout Code Matrix
        uses: actions/checkout@v3
        with:
          persist-credentials: true
          fetch-depth: 0

      - name: Initialize Python Runtime
        uses: actions/setup-python@v4
        with:
          python-version: '3.x'

      - name: Step 1 - Activate & Scan All Modules
        run: python "Modules/Active-Modules.py"

      - name: Step 2 - Execute Super Core Affiliate Processing
        run: python "Super Core Affiliate/Super-Core-Affiliate.py"

      - name: Step 3 - Validate and Harmonize Core Matrix
        run: |
          TARGET_FILE="Super Core Affiliate/system_bridge.json"
          if [ -s "$TARGET_FILE" ] && grep -q "active_modules_matrix" "$TARGET_FILE"; then
            echo "[SUCCESS] Ma trận truyền tải tín hiệu Module tích hợp hoàn toàn hợp lệ."
          else
            echo "[CRITICAL] Lỗi cấu trúc truyền tải dữ liệu! Chặn đứng để bảo vệ hệ thống."
            exit 1
          fi

      - name: Step 4 - Deploy Clean Signals to Landing Page
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          git config --global user.name "EATHESEN-CORE-BOT"
          git config --global user.email "core@donabicomedia.net"
          
          # Sao lưu file dữ liệu tổng hợp đã xử lý ra vùng nhớ tạm
          cp "Super Core Affiliate/system_bridge.json" /tmp/system_bridge.json
          
          # Đồng bộ cứng với máy chủ lưu trữ chính
          git fetch origin main
          git reset --hard origin/main
          
          # Ép đè file tĩnh ra ngoài thư mục gốc để index.html càn quét trực tiếp
          cp /tmp/system_bridge.json system_bridge.json
          cp /tmp/system_bridge.json "Super Core Affiliate/system_bridge.json"
          
          # Thực hiện Commit & Push tàng hình
          git add system_bridge.json "Super Core Affiliate/system_bridge.json"
          if ! git diff --cached --quiet; then
            git commit -m "¢24-SOTA-Modules: Sync Matrix & Active Nodes $(date -u +'%Y-%m-%d %H:%M:%S') UTC"
            git push https://x-access-token:${GITHUB_TOKEN}@github.com/${{ github.repository }}.git main
          else
            echo "[EATHESEN] Trạng thái ma trận không đổi, bỏ qua chu kỳ này."
          fi
